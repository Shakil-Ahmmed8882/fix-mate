// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Models live in sibling .prisma files inside this folder (prisma/schema).
// Add users.prisma, technician.prisma, booking.prisma, etc. as you design them.

generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
