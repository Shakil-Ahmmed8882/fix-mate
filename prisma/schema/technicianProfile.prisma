model TechnicianProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  skills          String[]
  experienceYears Int      @default(0)
  isAvailable     Boolean  @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  availabilitySlots AvailabilitySlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("technician_profiles")
}

model AvailabilitySlot {
  id                  String   @id @default(uuid())
  technicianProfileId String
  date                DateTime @db.Date // a specific calendar day, e.g. 2026-08-15
  startTime           String // canonical 24h "HH:mm", e.g. "09:00" (input is 12h "09:00 AM")
  endTime             String // canonical 24h "HH:mm", e.g. "17:00"

  technicianProfile TechnicianProfile @relation(fields: [technicianProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([technicianProfileId, date])
  @@map("availability_slots")
}
